{
  "name": "seiridesk",
  "private": true,
  "version": "0.1.0",
  "description": "SeiriDesk monorepo (NestJS + Next.js)",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:web",
    "dev:api": "npm run dev --workspace=@seiridesk/api",
    "dev:web": "npm run dev --workspace=@seiridesk/web",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "check": "npm run lint && npm run test"
  }
}
